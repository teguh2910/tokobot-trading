# Tokocrypto API Credentials
TOKO_API_KEY=your_api_key_here
TOKO_SECRET_KEY=your_secret_key_here

# Bot Settings
BOT_MODE=paper              # paper | live
BOT_STRATEGY=ma_cross       # ma_cross | rsi | grid
BOT_SYMBOLS=BTC_IDR,ETH_IDR # comma separated
BOT_INTERVAL=1m             # kline interval for strategy

# Risk Management
RISK_PER_TRADE=1.0          # % of balance per trade
RISK_REWARD_NUM=1           # risk:reward numerator (1:2)
RISK_REWARD_DEN=2           # risk:reward denominator (1:2)
SL_TYPE=fixed               # fixed | atr
SL_VALUE=1.0                # stop loss % if fixed
MAX_DAILY_LOSS=5.0          # max daily loss % before stop
MAX_OPEN_POSITIONS=3

# Grid Strategy (if applicable)
GRID_LEVELS=10
GRID_SPREAD_PCT=0.5         # % spread between grid levels
GRID_TOTAL_INVESTMENT=100   # in quote asset

# MA Crossover params
MA_FAST=9
MA_SLOW=21

# RSI params
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70

# Dashboard
DASHBOARD_PORT=8000
DASHBOARD_HOST=0.0.0.0
DASHBOARD_USER=admin
DASHBOARD_PASS=admin123

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
